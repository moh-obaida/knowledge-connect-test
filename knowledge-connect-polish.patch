+/* ── Display font for big Arabic headings ────────────────────
+   Use .kc-display on the game title, room-code stamps, and the
+   winner banner. Cairo remains the body / UI default — Naskh is
+   only for moments where presence matters. */
+.kc-display {
+  font-family: 'Noto Naskh Arabic', 'Cairo', serif;
+  font-weight: 700;
+  letter-spacing: 0;
+  line-height: 1.25;
+}
+
+/* Subtle shimmer on the winning hex path. Layered over the cell
+   outline animation defined in HexBoard. */
+@keyframes hexWin {
+  0%, 100% {
+    filter: brightness(1) drop-shadow(0 0 6px rgba(251, 191, 36, 0.55));
+  }
+  50% {
+    filter: brightness(1.18) drop-shadow(0 0 14px rgba(251, 191, 36, 0.85));
+  }
+}
+
+/* Skip-without-lock visual cue: a skipped letter stays available
+   but shows a faint tick so the host can see it's been seen. */
+.board-cell.was-skipped::after {
+  content: "";
+  position: absolute; inset: auto 4px 4px auto;
+  width: 6px; height: 6px; border-radius: 50%;
+  background: rgba(245, 158, 11, 0.45);
+}
