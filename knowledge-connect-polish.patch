+// ═══════════════════════════════════════════════════════════════
+// وصلة المعرفة — Per-letter question bank
+// ═══════════════════════════════════════════════════════════════
+//
+// Each Arabic letter has its own bank of questions. The structure is
+// designed to scale to ~50 questions per letter; this file ships with
+// ~3 placeholder questions per letter so the host can demo the flow
+// without authoring content first.
+//
+// All visible UI text is Arabic. The host is expected to add, edit,
+// and delete questions from this bank via the host dashboard. The
+// bank is data only — no game state, no Firebase coupling.
+
+import type { BoardCell } from "./store";
+
+export type DifficultyKey = "easy" | "medium" | "hard";
+
+export interface BankQuestion {
+  /** Stable id within the letter's bank. */
+  id: string;
+  /** The Arabic letter this question belongs to (e.g. "أ"). */
+  letter: string;
+  /** The question text shown to participants. */
+  question: string;
+  /** The expected answer. Should normally start with `letter`. */
+  answer: string;
+  /** Optional category, e.g. "ثقافة عامة", "علوم", "تاريخ". */
+  category: string;
+  difficulty: DifficultyKey;
+  /** 1–3 typically; mirrors BoardCell.points. */
+  points: number;
+  /** Optional Arabic hint. */
+  hint?: string;
+  /** Optional Arabic explanation shown after the answer is revealed. */
+  explanation?: string;
+}
+
+/** A bank is a map from Arabic letter → ordered list of questions. */
+export type QuestionBank = Record<string, BankQuestion[]>;
+
+// ─────────────────────────────────────────────────────────────
+// Helpers
+// ─────────────────────────────────────────────────────────────
+
+/**
+ * Pick a random question for a given letter that is not in the
+ * `excludeIds` set. Returns `undefined` when the bank for that letter
+ * is empty or fully exhausted.
+ */
+export function pickRandomFromBank(
+  bank: QuestionBank,
+  letter: string,
+  excludeIds: ReadonlySet<string> = new Set(),
+): BankQuestion | undefined {
+  const pool = (bank[letter] || []).filter((q) => !excludeIds.has(q.id));
+  if (pool.length === 0) return undefined;
+  return pool[Math.floor(Math.random() * pool.length)];
+}
+
+/**
+ * Get the Nth question for a letter (deterministic, for "next/prev"
+ * style host UX). Returns `undefined` if `index` is out of range.
+ */
+export function pickByIndex(
+  bank: QuestionBank,
+  letter: string,
+  index: number,
+): BankQuestion | undefined {
+  const list = bank[letter] || [];
+  if (index < 0 || index >= list.length) return undefined;
+  return list[index];
+}
+
+/** Number of questions available for a given letter. */
+export function bankSize(bank: QuestionBank, letter: string): number {
+  return (bank[letter] || []).length;
+}
+
+/**
+ * Apply a bank question onto a board cell so it becomes the cell's
+ * active question. The cell's `claimedBy` and `used` flags are NOT
+ * modified — choosing a question must never lock the letter.
+ */
+export function applyBankQuestionToCell(
+  cell: BoardCell,
+  q: BankQuestion,
+): BoardCell {
+  return {
+    ...cell,
+    question: q.question,
+    answer: q.answer,
+    category: q.category || cell.category,
+    difficulty: q.difficulty,
+    points: q.points || cell.points || 1,
+    hint: q.hint || "",
+    explanation: q.explanation || "",
+  };
+}
+
+// ─────────────────────────────────────────────────────────────
+// Default seed bank — placeholder questions, ~3 per letter.
+// Replace or extend in the host dashboard. Each entry is intentionally
+// short so the structure is the focus, not the content.
+// ─────────────────────────────────────────────────────────────
+
