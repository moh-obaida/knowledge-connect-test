# انسخ هذا الملف إلى `.env` في جذر المشروع (بجانب package.json و vite.config.ts).
# استبدل القيم ب placeholders أدناه بقيم مشروعك من Firebase Console → Project settings → Your apps.
#
# Copy to `.env` at the repository root. Replace every placeholder with your Firebase web app config.

VITE_FIREBASE_API_KEY=replace-with-your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
